{
	"schemaVersion": 1,
	"id": "robominecraft",
	"version": "${version}",
	"name": "RoboMinecraft",
	"description": "RoboMaster-inspired first-person robot chassis combat for Minecraft.",
	"authors": [
		"shtttt"
	],
	"contact": {
		"sources": "https://github.com/shtttt/RoboMinecraft"
	},
	"license": "CC0-1.0",
	"icon": "assets/robominecraft/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "com.robominecraft.RoboMinecraft",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "com.robominecraft.client.RoboMinecraftClient",
				"adapter": "kotlin"
			}
		],
		"fabric-datagen": [
			{
				"value": "com.robominecraft.client.RoboMinecraftDataGenerator",
				"adapter": "kotlin"
			}
		]
	},
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~1.21.10",
		"java": ">=21",
		"fabric-api": ">=0.138.4+1.21.10",
		"fabric-language-kotlin": ">=1.13.10+kotlin.2.3.20"
	}
}
